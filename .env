# 核心 API Key (擇一或全部填寫)
ANTHROPIC_API_KEY=你的_CLAUDE_API_KEY
OPENAI_API_KEY=你的_OPENAI_API_KEY

# 存取密鑰 (自訂一個複雜的字串，防止他人盜用你的 API)
OPENCLAW_GATEWAY_TOKEN=MySecretToken123

# 設定時區
TZ=Asia/Taipei

HOST=0.0.0.0
OPENCLAW_HOST=0.0.0.0
OPENCLAW_BIND=0.0.0.0
BIND_ADDRESS=0.0.0.0
# 讓 OpenClaw 允許 Docker 將流量轉出給你的 Mac
OPENCLAW_GATEWAY_BIND=lan

# 允許從 localhost 存取網頁介面 (防止被 OpenClaw 的安全機制擋下)
OPENCLAW_CONTROL_UI_DANGEROUSLY_ALLOW_HOST_HEADER_ORIGIN_FALLBACK=true
