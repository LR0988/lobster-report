{
  "language": "python",
  "phases": [
    {
      "name": "setup",
      "nixPkgs": ["python311", "python311Packages.pip", "postgresql"],
      "commands": [
        "cd backend",
        "pip install --upgrade pip",
        "pip install -r requirements.txt"
      ]
    },
    {
      "name": "build",
      "commands": []
    },
    {
      "name": "start",
      "start": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port $PORT"
    }
  ]
}
