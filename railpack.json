{
  "builders": [
    {
      "name": "backend",
      "path": "backend",
      "builder": "nixpacks",
      "nixpacksConfig": {
        "phases": [
          {
            "name": "setup",
            "nixPkgs": ["python311", "postgresql"],
            "commands": [
              "pip install -r requirements.txt"
            ]
          },
          {
            "name": "build",
            "commands": []
          },
          {
            "name": "start",
            "start": "./start.sh"
          }
        ],
        "variables": {
          "NIXPACKS_PYTHON_VERSION": "3.11"
        }
        ]
      }
    }
  ]
}
